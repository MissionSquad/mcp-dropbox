{
  "name": "@missionsquad/mcp-dropbox",
  "version": "0.2.1",
  "description": "A Model Context Protocol server for Dropbox integration",
  "type": "module",
  "bin": {
    "dbx-mcp-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "jest --config=jest.config.cjs --runInBand",
    "test:watch": "jest --watch --config=jest.config.cjs",
    "test:coverage": "jest --coverage --config=jest.config.cjs",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "dotenv": "^16.4.7",
    "dropbox": "^10.34.0",
    "express": "^5.1.0",
    "pino": "^9.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "nock": "^14.0.10",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
